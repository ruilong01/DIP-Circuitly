{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "no-undef": "warn",
    "no-unused-vars": "warn"
  },
  "globals": {
    "window": "readonly",
    "document": "readonly",
    "console": "readonly",
    "localStorage": "readonly",
    "alert": "readonly",
    "confirm": "readonly",
    "fetch": "readonly",
    "State": "readonly",
    "ROUTES": "readonly"
  }
}
